      "required": false,
      "children": [
        {
          "source_key": "borrower_ref",
          "target_xpath": "BorrowerRef",
          "type": "string25"
        },
        {
          "source_key": "borrower_dob",
          "target_xpath": "BorrowerDOB",
          "type": "date"
        }
      ]
    },
    {
      "source_column": "security_type",
