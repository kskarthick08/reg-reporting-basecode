      "allowed_values": ["A", "B", "C", "D", "E", "F", "W", "X", "Z"],
      "required": false
    },
    {
      "source_column": "total_amount_of_credit",
      "target_xpath": "CreditSalesDetails/TotalAmountCredit/TotalAmountOfCredit",
