ENVIRONMENT=local
API_PORT=8000
FRONTEND_PORT=3000
AUTO_RUN_MIGRATIONS=false
AUTO_CREATE_SCHEMA=true
STARTUP_PROBE_TIMEOUT_SECONDS=3

POSTGRES_DB=fca_app
POSTGRES_USER=fca_user
POSTGRES_PASSWORD=fca_pass
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://fca_user:fca_pass@postgres:5432/fca_app

#AXET_LLM_URL=http://host.containers.internal:41284/v1/chat/completions
AXET_LLM_URL=https://axet.nttdata.com/flows/cloud/hackthon-be/v1/chat/completions
AXET_LLM_MODEL=gpt-4.1-mini
AXET_LLM_VERIFY_SSL=false
LLM_LOG_PAYLOAD=false
LLM_LOG_MAX_CHARS=1200
APP_LOG_LEVEL=INFO
BA_LOG_PAYLOAD=false
BA_LOG_MAX_CHARS=1000
ADMIN_API_KEY=

EMBEDDING_DIM=768
