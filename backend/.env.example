# Copy this file to .env and update the values before starting the backend.
# The backend reads settings from this file via pydantic-settings.

# -----------------------------------------------------------------------
# Database - must point to the PostgreSQL instance with pgvector installed.
# Default matches the docker-compose service name "postgres".
# -----------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://fca_user:fca_pass@localhost:5431/fca_app

# -----------------------------------------------------------------------
# Redis (optional - only required if REQUIRE_REDIS=true)
# -----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REQUIRE_REDIS=false

# -----------------------------------------------------------------------
# Schema behavior
# AUTO_CREATE_SCHEMA=true creates missing tables from the complete model metadata.
# AUTO_APPLY_SCHEMA_PATCHES=true applies tracked idempotent schema patches for
# column additions, data normalization, and indexes that create_all cannot handle.
# -----------------------------------------------------------------------
AUTO_CREATE_SCHEMA=true
AUTO_APPLY_SCHEMA_PATCHES=true

# -----------------------------------------------------------------------
# LLM endpoint - Azure OpenAI or compatible deployment (required for LLM features)
# -----------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-with-your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# -----------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------
ENVIRONMENT=local
API_PORT=8000
APP_LOG_LEVEL=INFO
ADMIN_API_KEY=
EMBEDDING_DIM=768
